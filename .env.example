# ── WalkieTalkie Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your values

# MongoDB Atlas connection string (optional — app works without DB in memory-only mode)
# Get a free cluster at https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/walkie-talkie?retryWrites=true&w=majority

# Port (Railway/Render set this automatically)
PORT=3000

# Set to 'true' to disable HTTPS (use only if behind a reverse proxy that handles TLS)
# NO_HTTPS=true
